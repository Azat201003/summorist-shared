          "type": "integer",
          "format": "int64"
        },
        "jwtToken": {
          "type": "string",
          "title": "Only for upload"
        }
      }
    },
    "moresMeta": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "creatorId": {
          "type": "string",
